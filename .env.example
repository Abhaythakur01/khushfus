# ===========================================
# KhushFus Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ===========================================

# ===========================================
# Infrastructure
# ===========================================
DATABASE_URL=postgresql+asyncpg://khushfus:khushfus_dev@localhost:5432/khushfus
DATABASE_URL_SYNC=postgresql://khushfus:khushfus_dev@localhost:5432/khushfus
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# ===========================================
# App Settings
# ===========================================
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ===========================================
# Security (Identity Service)
# ===========================================
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# SMTP (Notification Service)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@khushfus.com

# ===========================================
# Platform API Keys (Collector Service)
# ===========================================

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# YouTube
YOUTUBE_API_KEY=

# News
NEWS_API_KEY=

# GDELT (free - no key needed)
GDELT_ENABLED=true

# Telegram (public channel names, comma-separated)
TELEGRAM_CHANNELS=

# Web Scraper (URLs to monitor, comma-separated)
SCRAPER_TARGET_URLS=

# TikTok
TIKTOK_ACCESS_TOKEN=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=

# Threads
THREADS_ACCESS_TOKEN=
THREADS_USER_IDS=me

# Bluesky
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Pinterest
PINTEREST_ACCESS_TOKEN=

# Facebook Publishing
FACEBOOK_PAGE_ID=

# LinkedIn Publishing
LINKEDIN_AUTHOR_URN=

# App Store / Play Store
APPLE_APP_IDS=
PLAY_STORE_PACKAGES=
APPSTORE_COUNTRY=us

# Review Platforms
TRUSTPILOT_API_KEY=
TRUSTPILOT_BUSINESS_IDS=
YELP_API_KEY=
YELP_BUSINESS_IDS=
G2_PRODUCT_URLS=

# Mastodon
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE_URL=https://mastodon.social

# Podcasts
LISTEN_NOTES_API_KEY=
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# ===========================================
# AI / NLP (Analyzer Service)
# ===========================================
ANTHROPIC_API_KEY=
SENTIMENT_MODEL=hybrid
USE_GPU=false
ANALYZER_BATCH_SIZE=20
HIGH_ENGAGEMENT_THRESHOLD=100

# ===========================================
# Integrations (Export Service)
# ===========================================
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
HUBSPOT_API_KEY=

# ===========================================
# Rate Limiter (Gateway Middleware)
# ===========================================
RATE_LIMITER_URL=http://rate-limiter:8014
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMITER_TIMEOUT=2

# ===========================================
# Media Service
# ===========================================
MEDIA_BATCH_SIZE=10
MEDIA_DOWNLOAD_TIMEOUT=30
MAX_MEDIA_SIZE_MB=50
MAX_VIDEO_KEYFRAMES=5
WHISPER_MODEL_SIZE=base
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
LOGO_CONFIDENCE_THRESHOLD=0.7

# ===========================================
# Observability
# ===========================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ===========================================
# Service Configuration
# ===========================================
COLLECTION_INTERVAL=3600
SCHEDULER_INTERVAL_SECONDS=60

# ===========================================
# Frontend
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
