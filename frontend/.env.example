# KhushFus Frontend Environment Variables
# Copy this file to .env.local and customize as needed.

# Backend API URL (gateway service) — REQUIRED in production
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time features (defaults to ws://localhost:8019)
# NEXT_PUBLIC_WS_URL=ws://localhost:8019

# Sentry DSN for error tracking (optional, enables Sentry if set)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Idle timeout in milliseconds (default: 1800000 = 30 min, 0 to disable)
# NEXT_PUBLIC_IDLE_TIMEOUT_MS=1800000

# Web Vitals analytics endpoint (optional, metrics POSTed here in production)
# NEXT_PUBLIC_VITALS_ENDPOINT=https://your-analytics.example.com/vitals
