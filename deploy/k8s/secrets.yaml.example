# KhushFus Kubernetes Secrets Template
#
# DO NOT commit real secrets to git. Use one of:
#   - kubectl create secret generic khushfus-secrets --from-env-file=.env
#   - Sealed Secrets (kubeseal)
#   - External Secrets Operator with Vault/AWS SM
#
# Copy this to secrets.yaml and fill in values before applying.
apiVersion: v1
kind: Secret
metadata:
  name: khushfus-secrets
  namespace: khushfus
type: Opaque
stringData:
  DATABASE_URL: "REPLACE_ME"
  POSTGRES_PASSWORD: "REPLACE_ME"
  JWT_SECRET_KEY: "REPLACE_ME"
  INTERNAL_SERVICE_TOKEN: "REPLACE_ME"
  WEBHOOK_SIGNING_SECRET: "REPLACE_ME"
  ANTHROPIC_API_KEY: "REPLACE_ME"
  SMTP_HOST: "smtp.gmail.com"
  SMTP_PORT: "587"
  SMTP_USER: "REPLACE_ME"
  SMTP_PASSWORD: "REPLACE_ME"
  # Platform API keys
  TWITTER_BEARER_TOKEN: "REPLACE_ME"
  FACEBOOK_PAGE_ACCESS_TOKEN: "REPLACE_ME"
  INSTAGRAM_ACCESS_TOKEN: "REPLACE_ME"
  LINKEDIN_ACCESS_TOKEN: "REPLACE_ME"
  YOUTUBE_API_KEY: "REPLACE_ME"
  NEWS_API_KEY: "REPLACE_ME"
  TIKTOK_ACCESS_TOKEN: "REPLACE_ME"
  DISCORD_BOT_TOKEN: "REPLACE_ME"
  DISCORD_CHANNEL_IDS: "REPLACE_ME"
  THREADS_ACCESS_TOKEN: "REPLACE_ME"
  BLUESKY_HANDLE: "REPLACE_ME"
  BLUESKY_APP_PASSWORD: "REPLACE_ME"
  PINTEREST_ACCESS_TOKEN: "REPLACE_ME"
  TRUSTPILOT_API_KEY: "REPLACE_ME"
  YELP_API_KEY: "REPLACE_ME"
  MASTODON_ACCESS_TOKEN: "REPLACE_ME"
  LISTEN_NOTES_API_KEY: "REPLACE_ME"
  PODCAST_INDEX_API_KEY: "REPLACE_ME"
  PODCAST_INDEX_API_SECRET: "REPLACE_ME"
